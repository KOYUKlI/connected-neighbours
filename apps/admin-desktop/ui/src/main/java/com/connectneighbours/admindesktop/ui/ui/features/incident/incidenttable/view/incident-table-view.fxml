<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>
<fx:root type="VBox"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         alignment="CENTER"
         fillWidth="false">
    <TableView fx:id="incidentTable" prefWidth="1500"
               prefHeight="500" style="-fx-background-radius:10;" stylesheets="@incident-table.css">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="90" minWidth="80"/>
            <TableColumn fx:id="titleColumn" text="Titre" prefWidth="220" minWidth="160"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="130" minWidth="100"/>
            <TableColumn fx:id="statusColumn" text="Statut" prefWidth="130" minWidth="120"/>
            <TableColumn fx:id="reporterColumn" text="Reporter" prefWidth="220" minWidth="180"/>
            <TableColumn fx:id="createdAtColumn" text="Créé le" prefWidth="130" minWidth="110"/>
            <TableColumn fx:id="resolvedAtColumn" text="Résolu le" prefWidth="130" minWidth="110"/>
            <TableColumn fx:id="alertsColumn" text="Alertes" prefWidth="90" minWidth="80"/>
        </columns>
    </TableView>

</fx:root>
