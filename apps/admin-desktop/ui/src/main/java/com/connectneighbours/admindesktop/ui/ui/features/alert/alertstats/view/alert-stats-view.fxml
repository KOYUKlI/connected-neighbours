<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<fx:root type="AnchorPane"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         prefWidth="640" prefHeight="180"
         style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

    <VBox spacing="15" alignment="CENTER" AnchorPane.topAnchor="10" AnchorPane.leftAnchor="10" AnchorPane.rightAnchor="10">
        <HBox spacing="15" alignment="CENTER">
            <VBox alignment="CENTER" prefWidth="200" prefHeight="100" style="-fx-background-color: #F8F8F8; -fx-background-radius: 8;">
                <Label text="Total Alertes" style="-fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Label fx:id="totalAlerts" text="4" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            </VBox>

            <VBox alignment="CENTER" prefWidth="200" prefHeight="100" style="-fx-background-color: #FDEEEE; -fx-background-radius: 8;">
                <Label text="Alertes Critiques" style="-fx-font-weight: bold; -fx-text-fill: #D91E25;"/>
                <Label fx:id="totalAlertsCritical" text="1" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #D91E25;"/>
            </VBox>

            <VBox alignment="CENTER" prefWidth="200" prefHeight="100" style="-fx-background-color: #F8F8F8; -fx-background-radius: 8;">
                <Label text="Temps de Résolution Moyen" style="-fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
                <Label fx:id="averageResolutionTime" text="2 heures" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A1A1A;"/>
            </VBox>
        </HBox>
    </VBox>
</fx:root>

