<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<fx:root type="VBox"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         fx:id="mainAlertContainer"
         spacing="10"
         maxWidth="750"
         prefWidth="750"
         style="-fx-background-color: #E8ECF8; -fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;">

    <HBox spacing="10" style="-fx-padding: 10 15 10 15;">
        <Button text="Retour"
                fx:id="btnReturn" styleClass="return-button">
            <graphic>
                <Label text="◀" styleClass="return-icon"/>
            </graphic>
        </Button>

        <Label text="Incident"
               style="
               -fx-font-size: 15;
               -fx-font-weight: bold;
               -fx-text-fill: #1A3E8A;
           "/>
    </HBox>

    <VBox spacing="10" fillWidth="false"
          fx:id="alertStatsContainer"
          style="-fx-border-color: #DDE1F0;
                 -fx-padding: 10 15 10 15;"
          alignment="CENTER">

        <HBox spacing="10" alignment="CENTER" fx:id="menuBtn">

            <HBox spacing="6" alignment="CENTER" styleClass="hbox-filter">
                <MenuBar styleClass="menu-bar">
                    <Menu fx:id="menuGravity" text="Gravité">
                        <MenuItem fx:id="gravityAll" text="Toutes"/>
                        <MenuItem fx:id="gravityCritical" text="Critique"/>
                        <MenuItem fx:id="gravityHigh" text="Haute"/>
                        <MenuItem fx:id="gravityMedium" text="Moyenne"/>
                        <MenuItem fx:id="gravityLow" text="Mineure"/>
                    </Menu>
                </MenuBar>
                <Label fx:id="gravityValue" text="Toutes"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER" styleClass="hbox-filter">
                <MenuBar styleClass="menu-bar">
                    <Menu fx:id="menuStatus" text="Statut">
                        <MenuItem fx:id="statusAll" text="Tous"/>
                        <MenuItem fx:id="statusResolved" text="Résolue"/>
                        <MenuItem fx:id="statusInProgress" text="En cours"/>
                        <MenuItem fx:id="statusClosed" text="Fermée"/>
                    </Menu>
                </MenuBar>
                <Label fx:id="statusValue" text="Tous"/>
            </HBox>

            <HBox spacing="6" alignment="CENTER" styleClass="hbox-filter">
                <MenuBar styleClass="menu-bar">
                    <Menu fx:id="menuDate" text="Date">
                        <MenuItem fx:id="dateAll" text="Toutes"/>
                        <MenuItem fx:id="dateToday" text="Aujourd’hui"/>
                        <MenuItem fx:id="dateWeek" text="Cette semaine"/>
                        <MenuItem fx:id="dateMonth" text="Ce mois"/>
                    </Menu>
                </MenuBar>
                <Label fx:id="dateValue" text="Toutes"/>
            </HBox>

            <Button text="Filtrer" fx:id="btnFilter" styleClass="filter-button"/>
        </HBox>

    </VBox>



    <VBox alignment="CENTER"
          style="-fx-padding: 10 15 10 15;">

        <HBox spacing="150" fx:id="alertDistribution">

            <VBox fx:id="alertsContainer"
                  fillWidth="false"
                  spacing="10"
                  alignment="TOP_RIGHT"/>

        </HBox>
    </VBox>

</fx:root>
