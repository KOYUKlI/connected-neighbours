<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.connectneighbours.admindesktop.ui.ui.AdminDesktopController"
            stylesheets="@style.css">
    <HBox fx:id="graphIncident" alignment="CENTER" spacing="20"/>
    <VBox fx:id="mainContainer"
          alignment="CENTER"
          spacing="20"
          AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <Label fx:id="welcomeText"/>
        <Button text="Hello!" onAction="#onHelloButtonClick"/>
<!--        <Button text="Synchroniser" onAction="#onSyncClicked" />-->

    </VBox>

</AnchorPane>


