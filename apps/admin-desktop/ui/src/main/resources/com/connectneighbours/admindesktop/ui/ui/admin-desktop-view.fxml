<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.*?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.connectneighbours.admindesktop.ui.ui.AdminDesktopController"
            stylesheets="@style.css">

    <VBox AnchorPane.topAnchor="0"
          AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0"
          AnchorPane.bottomAnchor="0">

        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="top-nav-bar">
            <MenuButton fx:id="navMenu" text="☰" styleClass="nav-menu-button">
                <items>
                    <MenuItem fx:id="navIncidents" text="Incidents"/>
                    <MenuItem fx:id="navPlugins" text="Plugins"/>
                    <MenuItem fx:id="navThemes" text="Thèmes"/>
                    <MenuItem fx:id="navSync" text="Historique Synchro"/>
                </items>
            </MenuButton>
            <Label text="Connect Neighbours" styleClass="top-nav-title"/>
            <Label fx:id="offlineBadge" text="Mode hors ligne" styleClass="offline-badge" visible="false" managed="false"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnLogout" text="Déconnexion" styleClass="logout-button"/>
        </HBox>

        <VBox fx:id="mainContainer"
              alignment="CENTER"
              spacing="20"
              styleClass="main-content-area"
              VBox.vgrow="ALWAYS">

            <Label fx:id="welcomeText"/>

        </VBox>

    </VBox>

</AnchorPane>
