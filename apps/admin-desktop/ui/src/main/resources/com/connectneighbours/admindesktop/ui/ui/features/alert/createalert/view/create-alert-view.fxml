<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<fx:root type="VBox"
         xmlns="http://javafx.com/javafx"
         xmlns:fx="http://javafx.com/fxml"
         fx:id="mainCreateAlertContainer"
         spacing="20"
         maxWidth="Infinity"
         prefWidth="750"
         VBox.vgrow="ALWAYS"
         stylesheets="@create-alert-view.css"
         styleClass="create-alert-container">

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Retour"
                fx:id="btnReturn" styleClass="return-button">
            <graphic>
                <Label text="◀" styleClass="return-icon"/>
            </graphic>
        </Button>

        <Label text="Créer une alerte"
               fx:id="formTitle"
               styleClass="form-title"/>
    </HBox>

    <VBox spacing="16" styleClass="form-card">
        <VBox spacing="6">
            <Label text="Titre de l'alerte" styleClass="form-label"/>
            <TextField fx:id="titleField" promptText="Titre de l'alerte" styleClass="form-field"/>
            <Label fx:id="titleError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Description de l'alerte" styleClass="form-label"/>
            <TextField fx:id="descriptionField" promptText="Description de l'alerte" styleClass="form-field"/>
            <Label fx:id="descriptionError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Gravité" styleClass="form-label"/>
            <HBox spacing="8" fx:id="severityBox">
                <ToggleButton text="Mineure" fx:id="severityLow" styleClass="severity-button"/>
                <ToggleButton text="Moyenne" fx:id="severityMedium" styleClass="severity-button"/>
                <ToggleButton text="Haute" fx:id="severityHigh" styleClass="severity-button"/>
                <ToggleButton text="Critique" fx:id="severityCritical" styleClass="severity-button"/>
            </HBox>
            <Label fx:id="severityError" styleClass="error-label" visible="false" managed="false"/>
        </VBox>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Annuler" fx:id="btnCancel" styleClass="return-button"/>
        <Button text="Créer" fx:id="btnCreate" styleClass="filter-button"/>
    </HBox>
</fx:root>
