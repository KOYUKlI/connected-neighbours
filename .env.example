NODE_ENV=development

HOST=0.0.0.0
PORT=3000

CORS_ORIGIN=http://localhost:5173,http://localhost:5174
COOKIE_SECRET=change-me-please

MONGODB_URI=mongodb://localhost:27017/connected_neighbours
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j
NEO4J_TIMEOUT_MS=2500
NEO4J_RETRY_COOLDOWN_MS=15000
GRAPH_SYNC_WORKER_ENABLED=true
GRAPH_SYNC_INTERVAL_MS=15000
GRAPH_SYNC_BATCH_SIZE=20

MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
# Host/port the browser can reach for presigned URLs (defaults to MINIO_ENDPOINT/PORT/USE_SSL above).
# Only needed when MINIO_ENDPOINT is a Docker-internal hostname, e.g. "minio", not reachable from the browser.
# MINIO_PUBLIC_ENDPOINT=localhost
# MINIO_PUBLIC_PORT=9000
# MINIO_PUBLIC_USE_SSL=false
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio-password
MINIO_BUCKET=connected-neighbours

# Local authentication remains enabled while web clients migrate to OIDC.
AUTH_LOCAL_ENABLED=true
KEYCLOAK_ENABLED=false
KEYCLOAK_INTERNAL_URL=http://localhost:8080
KEYCLOAK_PUBLIC_URL=http://localhost:8080
KEYCLOAK_REALM=connected-neighbours
KEYCLOAK_API_AUDIENCE=connected-neighbours-api
KEYCLOAK_WEB_CLIENT_ID=connected-neighbours-web
KEYCLOAK_ADMIN_CLIENT_ID=connected-neighbours-admin
KEYCLOAK_SERVICE_CLIENT_ID=connected-neighbours-service
KEYCLOAK_SERVICE_CLIENT_SECRET=replace-with-a-local-development-secret
KEYCLOAK_REQUEST_TIMEOUT_MS=2500

KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=replace-with-a-local-development-password
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=replace-with-a-local-development-password

MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Browser-side OIDC configuration. Public clients never have a secret.
VITE_KEYCLOAK_ENABLED=false
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=connected-neighbours
VITE_KEYCLOAK_CLIENT_ID=connected-neighbours-web
VITE_KEYCLOAK_ACCOUNT_URL=http://localhost:8080/realms/connected-neighbours/account

JWT_SECRET=change-this-with-a-long-random-string
JWT_EXPIRES_IN=1d
DEV_AUTH_SEED=true
