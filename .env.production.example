# Production environment template.
# Copy to `.env` on the production host ONLY (never commit the filled-in file)
# and replace every placeholder below with a real, unique value.
# Use with: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

NODE_ENV=production

HOST=0.0.0.0
PORT=3000

# Real public origins of the web/admin-web apps, comma-separated. No localhost.
CORS_ORIGIN=https://app.example.com,https://admin.example.com

# Generate with: openssl rand -base64 48
COOKIE_SECRET=REPLACE_WITH_A_UNIQUE_RANDOM_SECRET
JWT_SECRET=REPLACE_WITH_A_UNIQUE_RANDOM_SECRET
JWT_EXPIRES_IN=1d

MONGODB_URI=mongodb://mongodb:27017/connected_neighbours
NEO4J_ENABLED=true
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=REPLACE_WITH_A_UNIQUE_PASSWORD
NEO4J_DATABASE=neo4j
NEO4J_TIMEOUT_MS=2500
NEO4J_RETRY_COOLDOWN_MS=15000
GRAPH_SYNC_WORKER_ENABLED=true
GRAPH_SYNC_INTERVAL_MS=15000
GRAPH_SYNC_BATCH_SIZE=20

MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=REPLACE_WITH_A_UNIQUE_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_WITH_A_UNIQUE_SECRET_KEY
MINIO_BUCKET=connected-neighbours
# Public host/port the browser uses for presigned URLs — put this behind TLS
# (reverse proxy or load balancer), never expose MinIO's own port directly.
MINIO_PUBLIC_ENDPOINT=storage.example.com
MINIO_PUBLIC_PORT=443
MINIO_PUBLIC_USE_SSL=true

# Set to false once every client has fully migrated to Keycloak SSO.
AUTH_LOCAL_ENABLED=true
KEYCLOAK_ENABLED=true
KEYCLOAK_PUBLIC_URL=https://auth.example.com
KEYCLOAK_REALM=connected-neighbours
KEYCLOAK_API_AUDIENCE=connected-neighbours-api
KEYCLOAK_WEB_CLIENT_ID=connected-neighbours-web
KEYCLOAK_ADMIN_CLIENT_ID=connected-neighbours-admin
KEYCLOAK_SERVICE_CLIENT_ID=connected-neighbours-service
KEYCLOAK_SERVICE_CLIENT_SECRET=REPLACE_WITH_A_UNIQUE_RANDOM_SECRET
KEYCLOAK_REQUEST_TIMEOUT_MS=2500

KEYCLOAK_DB_NAME=keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=REPLACE_WITH_A_UNIQUE_PASSWORD
KEYCLOAK_ADMIN_USER=REPLACE_WITH_A_UNIQUE_ADMIN_USERNAME
KEYCLOAK_ADMIN_PASSWORD=REPLACE_WITH_A_UNIQUE_PASSWORD

MAILPIT_SMTP_HOST=mailpit
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# Browser-side OIDC configuration. Public clients never have a secret.
VITE_KEYCLOAK_ENABLED=true
VITE_KEYCLOAK_URL=https://auth.example.com
VITE_KEYCLOAK_REALM=connected-neighbours
VITE_KEYCLOAK_CLIENT_ID=connected-neighbours-web
VITE_KEYCLOAK_ACCOUNT_URL=https://auth.example.com/realms/connected-neighbours/account
VITE_ADMIN_KEYCLOAK_ENABLED=true
VITE_ADMIN_KEYCLOAK_CLIENT_ID=connected-neighbours-admin

# Never seed demo/test accounts in production.
DEV_AUTH_SEED=false
